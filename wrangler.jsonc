{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-story-game",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-18",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  }
  // Required secrets (set via `wrangler secret put`):
  //   SUPABASE_URL, SUPABASE_ANON_KEY, ADMIN_USER, ADMIN_PASS, SUPABASE_SERVICE_KEY
}
