{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-story-game",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-18",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "vars": {
    "SUPABASE_URL": "https://cjpbsgdjpodrfdyqhaja.supabase.co",
    "ADMIN_USER": "admin"
  }
  // Required secrets (set via Cloudflare Dashboard):
  //   SUPABASE_ANON_KEY, ADMIN_PASS, SUPABASE_SERVICE_KEY
}
