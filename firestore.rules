rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 세션: 인증된 사용자만 생성, 소유자만 수정, 누구나 읽기
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['title', 'createdAt', 'ownerUid'])
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['messages', 'updatedAt', 'lastPlayedAt', 'title', 'ttl', 'summary', 'summaryUpToIndex', 'playerPreset', 'model']);
      allow delete: if false;
    }

    // 스토리: 인증된 사용자만 생성, 소유자만 수정 (+ 암호 해시 일치)
    match /stories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['title', 'createdAt', 'ownerUid'])
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.passwordHash == resource.data.passwordHash;
      allow delete: if false;
    }

    // 프리셋: 읽기만 허용
    match /presets/{presetId} {
      allow read: if true;
      allow create, update, delete: if false;
    }
  }
}
